# Environment variables read by framegrabber.py. In k8s these come from the ConfigMap
# (non-secret) + a Secret (NTFY_TOKEN). For a local run, export them or use an env file.

# ntfy server + topic. On free ntfy.sh the topic IS the secret (keep it unguessable). On a
# self-hosted access-controlled server, writes are protected by NTFY_TOKEN so the topic can be
# a friendly shareable name. Subscribe to <NTFY_SERVER>/<NTFY_TOPIC> on your phone.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=steamframe-CHANGEME-pick-something-random

# Publish token (tk_…), required when the server denies anonymous publishing (self-hosted ntfy
# with auth-default-access: read-only). Leave empty for a default ntfy.sh topic.
NTFY_TOKEN=

# Optional overrides (defaults shown):
# FRAMEGRABBER_STATE=/data/state.json    # JSON state file (put on a persistent volume)
# FRAMEGRABBER_CC=us
# FRAMEGRABBER_APPIDS=4165890            # space/comma separated; add 4165910 to also watch Steam Machine
# FRAMEGRABBER_NEWS_FEEDS=<url> <url>    # override the official Valve RSS feeds watched (default:
#                                        #   group 4145017 + group 45479024 + app 4165890 feeds)
# FRAMEGRABBER_PRIMARY_ONLY=1            # set to skip the news signal (appdetails only)
