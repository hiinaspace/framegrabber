# Copy to ~/.config/framegrabber/env and `chmod 600` it. The systemd unit loads this file.

# ntfy server + topic. On the free ntfy.sh, the topic IS the secret (keep it unguessable).
# On a self-hosted access-controlled server, writes are protected by NTFY_TOKEN, so the topic
# can be a friendly shareable name. Subscribe to <NTFY_SERVER>/<NTFY_TOPIC> on your phone.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=steamframe-CHANGEME-pick-something-random

# Publish token (tk_…), required when the server denies anonymous publishing. Leave empty for
# a default ntfy.sh topic. On self-hosted ntfy:
#   ntfy user add --role=admin publisher && ntfy token add publisher
NTFY_TOKEN=

# Optional overrides (defaults shown):
# FRAMEGRABBER_CC=us
# FRAMEGRABBER_APPIDS=4165890           # space/comma separated; add 4165910 to also watch Steam Machine
# FRAMEGRABBER_CLAUDE_MODEL=claude-haiku-4-5-20251001
# FRAMEGRABBER_CLAUDE_BIN=claude        # name or absolute path of the claude CLI, e.g. /home/you/.local/bin/claude
# FRAMEGRABBER_PRIMARY_ONLY=1           # set to skip the LLM-triaged landing-page + news signals
